# PostgreSQL (required for auth and storing analyses)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/legaldoc

# JWT secret for auth tokens (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32

# Groq (for LLM analysis) - already used by the app
# GROQ_API_KEY=your_groq_api_key
